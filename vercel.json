{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/analytics",
      "destination": "/index.html"
    },
    {
      "source": "/analytics/",
      "destination": "/index.html"
    },
    {
      "source": "/produk-sekolah",
      "destination": "/school-product.html"
    },
    {
      "source": "/produk-sekolah/",
      "destination": "/school-product.html"
    },
    {
      "source": "/produk-absensi",
      "destination": "/customer-product.html"
    },
    {
      "source": "/produk-absensi/",
      "destination": "/customer-product.html"
    },
    {
      "source": "/produk",
      "destination": "/school-product.html"
    },
    {
      "source": "/produk/",
      "destination": "/school-product.html"
    },
    {
      "source": "/demo-sekolah",
      "destination": "/demo-school.html"
    },
    {
      "source": "/demo-sekolah/",
      "destination": "/demo-school.html"
    },
    {
      "source": "/demo",
      "destination": "/demo-school.html"
    },
    {
      "source": "/demo/",
      "destination": "/demo-school.html"
    }
  ]
}
